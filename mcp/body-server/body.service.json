{
  "schemaVersion": 1,
  "name": "body",
  "kind": "bridge",
  "runtime": "bridge",
  "addon": "body",
  "roles": [
    "hub",
    "spoke"
  ],
  "portVar": "BODY_BRIDGE_PORT",
  "stdio": [
    "${NODE_BIN}",
    "${REPO_ROOT}/mcp/body-server/server.mjs"
  ],
  "env": {
    "CRM_BASE_URL": "${BOARD_URL}"
  },
  "idleExit": true,
  "clients": [
    "claude-code",
    "cowork"
  ],
  "probe": {
    "type": "httpListen"
  }
}
