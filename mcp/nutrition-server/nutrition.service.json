{
  "schemaVersion": 1,
  "name": "nutrition",
  "kind": "bridge",
  "runtime": "bridge",
  "addon": "nutrition",
  "portVar": "NUTRITION_BRIDGE_PORT",
  "stdio": ["${NODE_BIN}", "${REPO_ROOT}/mcp/nutrition-server/server.mjs"],
  "env": { "CRM_BASE_URL": "${BOARD_URL}" },
  "idleExit": true,
  "clients": ["claude-code", "cowork"],
  "probe": { "type": "httpListen" }
}
