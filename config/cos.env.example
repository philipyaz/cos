# Cos — machine-local PUBLIC config (paths / ports / binaries for SKILLS + SETUP).
#
# This is the TEMPLATE. cos-setup GENERATES the real config/cos.env (gitignored) by detecting
# your machine — you normally never copy this by hand. To write it manually anyway:
#     cp config/cos.env.example config/cos.env   # then edit the values
#
# NO SECRETS HERE. The split across config/ is:
#     config/cos.env        machine paths / ports / binaries   (this file's real twin; gitignored)
#     config/secrets.env    the Anthropic API key              (gitignored)
#     config/settings.json  board/app prefs: principalEmail, theme, autoSync, … (gitignored)
#     config/auto-sync.json router auto-sync switch            (committed)
#
# Skills read this file via the loader — the first line of their first shell block:
#     source "$(git rev-parse --show-toplevel)/config/load-config.sh"
# The loader derives REPO_ROOT from git (NOT stored here), seeds these values as defaults when
# the file is absent, then lets the file override them, then computes derived values like
# VAULT_DIR and BOARD_URL.
#
# ALWAYS QUOTE values. macOS paths such as "Application Support" contain a space; an unquoted
# value breaks `source` (the shell tries to run the part after the space as a command).

# --- Toolchain (Homebrew prefix: /opt/homebrew on Apple Silicon, /usr/local on Intel) ---------
BREW_PREFIX="/opt/homebrew"
NODE_BIN="/opt/homebrew/bin/node"
UV_BIN="/opt/homebrew/bin/uv"
SUPERGATEWAY_BIN="/opt/homebrew/bin/supergateway"

# --- macOS locations (everything under your $HOME) --------------------------------------------
LAUNCH_AGENTS_DIR="/Users/you/Library/LaunchAgents"
COWORK_CONFIG="/Users/you/Library/Application Support/Claude/claude_desktop_config.json"
OPENWHISPR_DB="/Users/you/Library/Application Support/open-whispr/transcriptions.db"
OPENWHISPR_AUDIO_DIR="/Users/you/Library/Application Support/open-whispr/audio"
BACKUP_REPO="/Users/you/.cos-backups"

# --- Active vault (filled by setup-vault; blank / absent → the example-vault template) ---------
VAULT_NAME=""

# --- Ports (architectural constants; change only to dodge a local clash) ----------------------
BOARD_PORT="3000"
BOARD_BRIDGE_PORT="8001"
OPENWHISPR_BRIDGE_PORT="8002"
CALENDAR_BRIDGE_PORT="8003"
GUARD_BRIDGE_PORT="8004"
VAULT_BRIDGE_PORT="8005"
SEARCH_SIDECAR_PORT="8008"
GUARD_SIDECAR_PORT="8009"

# --- Guard classifier (config, not code; the manifest's guardsvc descriptor reads these) -----
# COS_GUARD_MODEL selects the prompt-injection classifier. Default = the gated Llama-Prompt-Guard-2-86M
# (real model; needs the HF license + a one-time prefetch + the `model` uv extra — see guard-setup).
# A machine without it (e.g. Windows with no CUDA/Metal) sets "heuristic-only" here — a per-machine
# SETTING, never a per-OS code fork. The guard MCP fails CLOSED regardless. THRESHOLD is the cutoff.
COS_GUARD_MODEL="llama-prompt-guard-2-86m"
COS_GUARD_THRESHOLD="0.5"

# --- WhatsApp MCP add-on (external repo verygoodplugins/whatsapp-mcp) --------------------------
# WHATSAPP_MCP_DIR is the sibling checkout (built + paired by the whatsapp-mcp-setup skill).
# WHATSAPP_GO_PORT is the Go whatsmeow bridge sidecar (whatsmeow's default 8080 is usually taken,
# so cos pins 8010); WHATSAPP_MCP_BRIDGE_PORT is the supergateway HTTP bridge for Claude Code.
WHATSAPP_MCP_DIR="/Users/you/Code/whatsapp-mcp"
WHATSAPP_MCP_BRIDGE_PORT="8006"
WHATSAPP_GO_PORT="8010"

# --- Nutrition & Chef add-on ------------------------------------------------------------------
# Built-in add-on (in-repo mcp/nutrition-server, no external checkout). NUTRITION_BRIDGE_PORT is
# the supergateway HTTP bridge for Claude Code; the add-on is gated per-board via Settings.addons,
# so naming the port here only documents it — it does not enable the add-on.
NUTRITION_BRIDGE_PORT="8007"

# --- Fitness add-on ---------------------------------------------------------------------------
# Built-in add-on (in-repo mcp/fitness-server, no external checkout). FITNESS_BRIDGE_PORT is the
# supergateway HTTP bridge for Claude Code; the add-on is gated per-board via Settings.addons,
# so naming the port here only documents it — it does not enable the add-on.
FITNESS_BRIDGE_PORT="8011"
